# Copia questo file in .env.local e compila i valori

# Token Meta (Long-Lived Token - dura 60 giorni)
META_ACCESS_TOKEN=il_tuo_token_qui

# ID Account Meta del cliente (es: act_116713878687435)
META_AD_ACCOUNT_ID=act_116713878687435

# Parola chiave per filtrare le campagne Meraviglia
CAMPAIGN_FILTER_KEYWORD=Meraviglia

# Secret per proteggere l'API route (genera una stringa random)
API_SECRET=cambia_questo_con_una_stringa_random
